{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    { "source": "/style.min.css", "destination": "/css/style.min.css", "permanent": true },
    { "source": "/script.min.js", "destination": "/js/script.min.js", "permanent": true },
    { "source": "/projects.min.js", "destination": "/js/projects.min.js", "permanent": true }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "DENY" }, { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }, { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }] },
    { "source": "/css/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/js/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }] }
  ]
}
